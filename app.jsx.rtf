                  <div style=\{\{display:"flex",gap:10,textAlign:"center"\}\}>\
                    <div><div style=\{\{fontFamily:"'Barlow Condensed',sans-serif",fontSize:18,fontWeight:800,color:"#60a5fa",lineHeight:1\}\}>\{shots\}</div><div style=\{\{color:"#6b7280",fontSize:9\}\}>shots</div></div>\
                    <div><div style=\{\{fontFamily:"'Barlow Condensed',sans-serif",fontSize:18,fontWeight:800,color:"#34d399",lineHeight:1\}\}>\{hits\}</div><div style=\{\{color:"#6b7280",fontSize:9\}\}>hits</div></div>\
