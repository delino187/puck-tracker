      <div style=\{\{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:6,marginBottom:10\}\}><StatCard label="Sets Left" value=\{sLeft\} color="#fbbf24"/><StatCard label="Shots" value=\{sShots\} color="#60a5fa"/><StatCard label="Hits" value=\{sHits\} color="#34d399"/><StatCard label="Acc" value=\{sShots>0?sAcc+"%":"\'97"\} color="#c084fc"/></div>\
