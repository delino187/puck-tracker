          \{tab==="dashboard"  &&<DashTab player=\{aPlayer\} stats=\{stats\} sessions=\{st.sessions\} dailyChallenge=\{st.dailyChallenge\} weeklyChallenge=\{st.weeklyChallenge\} players=\{st.players\} onStartSession=\{()=>\{startSession();setTab("session");\}\} newBadgeIds=\{newBadgeIds\} onBadgeClick=\{b=>setBadgePreview(\{badge:b\})\}/>\}\
          \{tab==="session"    &&<SessionTab player=\{aPlayer\} session=\{aSess\} sesGoal=\{sesGoal\} setSesGoal=\{setSesGoal\} onLogSet=\{handleLogSet\} onEndSession=\{endSession\} onStart=\{startSession\} dailyChallenge=\{st.dailyChallenge\} weeklyChallenge=\{st.weeklyChallenge\} flashZone=\{flashZone\} flashType=\{flashType\} puckAnim=\{puckAnim\}/>\}\
          \{tab==="challenges" &&<ChallengesTab player=\{aPlayer\} sessions=\{st.sessions\} dailyChallenge=\{st.dailyChallenge\} weeklyChallenge=\{st.weeklyChallenge\} h2h=\{st.h2h\} players=\{st.players\}/>\}\
          \{tab==="board"      &&<BoardTab player=\{aPlayer\} players=\{st.players\} sessions=\{st.sessions\} h2h=\{st.h2h\}/>\}\
          \{tab==="stats"      &&<StatsTab player=\{aPlayer\} stats=\{stats\} sessions=\{st.sessions\}/>\}\
          \{tab==="badges"     &&<BadgesTab player=\{aPlayer\} sessions=\{st.sessions\} newBadgeIds=\{newBadgeIds\} onBadgeClick=\{b=>setBadgePreview(\{badge:b\})\}/>\}\
          \{tab==="ranks"      &&<RanksTab stats=\{stats\}/>\}\
        </div>\
