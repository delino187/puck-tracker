            <button style=\{\{background:"transparent",color:"#6b7280",border:"1px solid #334155",borderRadius:8,padding:"7px 12px",fontFamily:"'Barlow Condensed',sans-serif",fontSize:13,cursor:"pointer",display:"flex",alignItems:"center",gap:4\}\} onClick=\{()=>upd(\{view:"home"\})\}><Lock size=\{13\}/>Lock</button>\
          </div>\
