  const [msgDraft,setMsgDraft]=useState("");\
  const [msgSaved,setMsgSaved]=useState(false);\
\
  if(selectedPlayer)\{\
    const p=st.players.find(x=>x.id===selectedPlayer);\
    if(!p)\{setSelectedPlayer(null);return null;\}\
