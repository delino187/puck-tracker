function CoachMatchups(\{st,upd\})\{\
  const [p1,setP1]=useState(st.h2h?.p1||"");\
  const [p2,setP2]=useState(st.h2h?.p2||"");\
  const [saved,setSaved]=useState(!!st.h2h);\
  const ws=getWeekStart();\
  const randomize=()=>\{if(st.players.length<2)return;const s=[...st.players].sort(()=>Math.random()-0.5);setP1(s[0].id);setP2(s[1].id);setSaved(false);\};\
  const cur=st.h2h?.p1&&st.h2h?.p2?\{p1:st.players.find(p=>p.id===st.h2h.p1),p2:st.players.find(p=>p.id===st.h2h.p2),s1:st.sessions.filter(s=>s.playerId===st.h2h.p1&&new Date(s.date)>=ws).flatMap(s=>s.sets).length*10,s2:st.sessions.filter(s=>s.playerId===st.h2h.p2&&new Date(s.date)>=ws).flatMap(s=>s.sets).length*10\}:null;\
  return(\
