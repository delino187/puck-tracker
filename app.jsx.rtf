            <div><div style=\{\{fontFamily:"'Barlow Condensed',sans-serif",fontSize:20,fontWeight:900,color:"#f1f5f9"\}\}>\{p.name\}\{p.jerseyNum?<span style=\{\{color:"#60a5fa"\}\}> #\{p.jerseyNum\}</span>:""\}</div><LevelBadge li=\{getLevel(calcXP(getPSessions(p,st.sessions).flatMap(s=>s.sets).length*10,getPSessions(p,st.sessions).flatMap(s=>s.sets).reduce((a,x)=>a+x.hits,0))).li\}/></div>\
          </div>\
