        \{topBadge&&<BadgePopup badge=\{topBadge\} earned earnedDate=\{earnedBadgeObj[topBadge.id]?.ts||Date.now()\} onClose=\{()=>setBadgeQueue(prev=>prev.slice(1))\}/>\}\
        \{!topBadge&&badgePreview&&<BadgePopup badge=\{badgePreview.badge\} earned=\{!!earnedBadgeObj[badgePreview.badge.id]\} earnedDate=\{earnedBadgeObj[badgePreview.badge.id]?.ts\} onClose=\{()=>setBadgePreview(null)\}/>\}\
        \{levelPopup&&!topBadge&&<LevelUpPopup level=\{levelPopup\} onClose=\{()=>setLevelPopup(null)\}/>\}\
        \{celeb&&!topBadge&&<CelebOverlay data=\{celeb\} onClose=\{()=>setCeleb(null)\}/>\}\
        <PlayerHeader player=\{aPlayer\} stats=\{stats\} onBack=\{()=>upd(\{view:"playerSelect",activePlayerId:null,activeSessionId:null\})\}/>\
        <TabBar active=\{tab\} onChange=\{setTab\} hasSess=\{!!st.activeSessionId\}/>\
