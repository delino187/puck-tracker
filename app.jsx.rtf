  if(st.view==="playerSelect")return(<PlayerSelectScreen players=\{st.players\} sessions=\{st.sessions\} onSelect=\{(id)=>\{upd(\{activePlayerId:id,activeSessionId:null,view:"player"\});setTab("dashboard");\}\} onBack=\{()=>upd(\{view:"home"\})\}/>);\
\
